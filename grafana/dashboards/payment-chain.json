{
  "title": "支付链路耗时",
  "panels": [
    {
      "title": "P50 / P99 支付总耗时 (ms)",
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{job=\"payment-gateway\",uri=\"/api/v1/pay/create\"}[5m])) by (le)) * 1000", "legendFormat": "P50" },
        { "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{job=\"payment-gateway\",uri=\"/api/v1/pay/create\"}[5m])) by (le)) * 1000", "legendFormat": "P99" }
      ], "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8}
    },
    {
      "title": "网关内部各环节耗时估算 (请求量)",
      "targets": [
        { "expr": "rate(http_server_requests_seconds_count{job=\"payment-gateway\",uri=\"/api/v1/pay/create\"}[1m])", "legendFormat": "支付总请求" },
        { "expr": "rate(http_server_requests_seconds_count{job=\"merchant-service\",uri=~\"/api/v1/merchant/.*\"}[1m])", "legendFormat": "商户服务" },
        { "expr": "rate(http_server_requests_seconds_count{job=\"channel-simulator\",uri=\"/api/v1/simulator/pay\"}[1m])", "legendFormat": "渠道调用" },
        { "expr": "rate(http_server_requests_seconds_count{job=\"account-service\",uri=\"/api/v1/account/tcc/try\"}[1m])", "legendFormat": "TCC Try" },
        { "expr": "rate(http_server_requests_seconds_count{job=\"account-service\",uri=\"/api/v1/account/tcc/confirm\"}[1m])", "legendFormat": "TCC Confirm" }
      ], "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8}
    },
    {
      "title": "渠道模拟器延迟 (ms)",
      "targets": [{
        "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{job=\"channel-simulator\",uri=\"/api/v1/simulator/pay\"}[1m])) by (le)) * 1000"
      }], "gridPos": {"x": 0, "y": 8, "w": 12, "h": 7}
    },
    {
      "title": "TCC Confirm 延迟 (ms)",
      "targets": [{
        "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{job=\"account-service\",uri=\"/api/v1/account/tcc/confirm\"}[1m])) by (le)) * 1000"
      }], "gridPos": {"x": 12, "y": 8, "w": 12, "h": 7}
    }
  ]
}
